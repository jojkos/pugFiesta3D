# Frontend (all variables are exposed in the browser bundle)
VITE_SUPABASE_URL=https://xlwwkcpvnrpdptzgsxsu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# ElevenLabs key used directly from the browser. Yes, this is public — see
# src/game/useFunnySpeech.ts for the trade-off. Rotate if abuse appears.
VITE_ELEVENLABS_API_KEY=

# Server-only (used by api/* Vercel functions). NEVER prefix these with VITE_
# or they leak into the browser bundle.
SUPABASE_URL=https://xlwwkcpvnrpdptzgsxsu.supabase.co
# New-style secret key (Supabase → Settings → API Keys → Secret keys, sb_secret_…).
# The modern replacement for the legacy service_role key; bypasses RLS.
SUPABASE_SECRET_KEY=
# Random secret for signing score-submit session tokens: openssl rand -hex 32
SCORE_SIGNING_SECRET=
